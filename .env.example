# Experience Builder CLI Configuration
# 
# HOW TO USE:
# 1. Copy this file to .env in your project directory
# 2. Or run 'xb init' to create your configuration interactively
# 3. Fill in your values below
#
# ALTERNATIVE: 
# Create a .xbrc file in your home directory for global settings

# Required settings
EXPERIENCE_BUILDER_SITE_URL=https://example.com
# You can generate this token from /admin/config/services/experience-builder/tokens 
# in your Drupal site with Experience Builder installed
EXPERIENCE_BUILDER_AUTH_TOKEN=your_api_token

# Optional settings
EXPERIENCE_BUILDER_FRAMEWORK=react
EXPERIENCE_BUILDER_COMPONENT_DIR=./components
EXPERIENCE_BUILDER_VERBOSE=false

# Note: Command line arguments will override these environment variables
# Example: xb upload --url=https://example.com --token=your_token
